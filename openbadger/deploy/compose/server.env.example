OPENBADGER_DATABASE_URL=postgres://openbadger:openbadger@postgres:5432/openbadger?sslmode=disable
OPENBADGER_SERVER_ADDRESS=0.0.0.0:8080
OPENBADGER_SERVER_ENROLLMENT_TOKEN=replace-with-bootstrap-token
OPENBADGER_SERVER_ADMIN_USERNAME=admin
OPENBADGER_SERVER_ADMIN_PASSWORD=replace-with-admin-password
OPENBADGER_SERVER_ADMIN_SESSION_SECRET=replace-with-session-secret
OPENBADGER_SERVER_CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-32-byte-key
OPENBADGER_SERVER_EXPECTED_HEARTBEAT_INTERVAL=30s
OPENBADGER_SERVER_STALE_AFTER_MISSED_HEARTBEATS=3
OPENBADGER_SERVER_OBSERVATION_RETENTION=720h
