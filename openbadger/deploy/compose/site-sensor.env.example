OPENBADGER_SENSOR_NAME=sensor-site-a
OPENBADGER_SENSOR_SERVER_URL=http://host.docker.internal:8080
OPENBADGER_SENSOR_SITE_ID=site-a
OPENBADGER_SENSOR_ENROLLMENT_TOKEN=replace-with-bootstrap-token
OPENBADGER_SENSOR_STATE_PATH=/var/lib/openbadger/sensor-state.json
OPENBADGER_SENSOR_INTERFACE=eth0
OPENBADGER_SENSOR_HEARTBEAT_INTERVAL=30s
OPENBADGER_SENSOR_CAPTURE_WINDOW=10s
OPENBADGER_SENSOR_READ_TIMEOUT=500ms
OPENBADGER_SENSOR_PROMISCUOUS=false
OPENBADGER_SENSOR_SNAP_LEN=1600
